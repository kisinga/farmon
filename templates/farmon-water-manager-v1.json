{
  "type": "airconfig",
  "fields": [
    { "key": "level_pct", "display_name": "Tank Level", "unit": "%", "data_type": "number", "category": "telemetry", "access": "r", "state_class": "m", "min_value": 0, "max_value": 100, "report_mode": "reported", "sort_order": 0 },
    { "key": "flow_t1_rate", "display_name": "Flow T1 Rate", "unit": "L/interval", "data_type": "number", "category": "telemetry", "access": "r", "state_class": "m", "min_value": 0, "max_value": 9999, "report_mode": "reported", "sort_order": 1 },
    { "key": "flow_t1_total", "display_name": "Flow T1 Total", "unit": "L", "data_type": "number", "category": "telemetry", "access": "r", "state_class": "i", "min_value": 0, "max_value": 999999, "report_mode": "reported", "sort_order": 2 },
    { "key": "flow_t2_rate", "display_name": "Flow T2 Rate", "unit": "L/interval", "data_type": "number", "category": "telemetry", "access": "r", "state_class": "m", "min_value": 0, "max_value": 9999, "report_mode": "reported", "sort_order": 3 },
    { "key": "flow_t2_total", "display_name": "Flow T2 Total", "unit": "L", "data_type": "number", "category": "telemetry", "access": "r", "state_class": "i", "min_value": 0, "max_value": 999999, "report_mode": "reported", "sort_order": 4 },
    { "key": "battery", "display_name": "Battery", "unit": "%", "data_type": "number", "category": "system", "access": "r", "state_class": "m", "min_value": 0, "max_value": 100, "report_mode": "reported", "sort_order": 5 },
    { "key": "transfer_state", "display_name": "Transfer State", "unit": "", "data_type": "number", "category": "system", "access": "r", "state_class": "m", "min_value": 0, "max_value": 2, "report_mode": "reported", "sort_order": 6 },
    { "key": "pump_output", "display_name": "Pump State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "pump", "report_mode": "on_change", "sort_order": 10 },
    { "key": "valve_t1_output", "display_name": "Tank 1 Valve State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "valve_t1", "report_mode": "on_change", "sort_order": 11 },
    { "key": "valve_t2_output", "display_name": "Tank 2 Valve State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "valve_t2", "report_mode": "on_change", "sort_order": 12 },
    { "key": "flow_valve_t1_output", "display_name": "Flow Valve T1 State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "flow_valve_t1", "report_mode": "on_change", "sort_order": 13 },
    { "key": "flow_valve_t2_output", "display_name": "Flow Valve T2 State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "flow_valve_t2", "report_mode": "on_change", "sort_order": 14 },
    { "key": "solenoid_output", "display_name": "Solenoid State", "data_type": "number", "category": "telemetry", "access": "r", "linked_type": "output", "linked_key": "solenoid", "report_mode": "on_change", "sort_order": 15 }
  ],
  "controls": [
    { "key": "pump", "display_name": "Transfer Pump", "states": ["off", "on"], "control_type": "binary", "field_key": "pump_output", "pin_index": 6, "actuator_type": 0, "flags": 1, "pin2_index": 255, "pulse_x100ms": 0, "sort_order": 0 },
    { "key": "valve_t1", "display_name": "Tank 1 Valve", "states": ["closed", "open"], "control_type": "binary", "field_key": "valve_t1_output", "pin_index": 7, "actuator_type": 1, "flags": 5, "pin2_index": 8, "pulse_x100ms": 50, "sort_order": 1 },
    { "key": "valve_t2", "display_name": "Tank 2 Valve", "states": ["closed", "open"], "control_type": "binary", "field_key": "valve_t2_output", "pin_index": 9, "actuator_type": 1, "flags": 5, "pin2_index": 10, "pulse_x100ms": 50, "sort_order": 2 },
    { "key": "flow_valve_t1", "display_name": "Flow Valve T1", "states": ["closed", "open"], "control_type": "binary", "field_key": "flow_valve_t1_output", "pin_index": 11, "actuator_type": 0, "flags": 1, "pin2_index": 255, "pulse_x100ms": 0, "sort_order": 3 },
    { "key": "flow_valve_t2", "display_name": "Flow Valve T2", "states": ["closed", "open"], "control_type": "binary", "field_key": "flow_valve_t2_output", "pin_index": 12, "actuator_type": 0, "flags": 1, "pin2_index": 255, "pulse_x100ms": 0, "sort_order": 4 },
    { "key": "solenoid", "display_name": "Solenoid SV", "states": ["off", "pulse"], "control_type": "binary", "field_key": "solenoid_output", "pin_index": 13, "actuator_type": 2, "flags": 9, "pin2_index": 255, "pulse_x100ms": 20, "sort_order": 5 }
  ],
  "commands": [
    { "name": "reset", "fport": 10, "payload_type": "empty" },
    { "name": "interval", "fport": 11, "payload_type": "uint16_le_seconds" },
    { "name": "reboot", "fport": 12, "payload_type": "empty" },
    { "name": "ctrl", "fport": 20, "payload_type": "control_binary" },
    { "name": "rule", "fport": 30, "payload_type": "rule_binary" }
  ],
  "decode_rules": [
    { "fport": 2, "format": "binary_indexed_float32", "config": {
      "count_offset": 0, "entries_offset": 1, "entry_size": 5, "index_offset": 0, "value_offset": 1
    }},
    { "fport": 3, "format": "binary_state_change", "config": {
      "record_size": 11,
      "layout": [
        { "offset": 0, "name": "control_idx", "type": "uint8" },
        { "offset": 1, "name": "new_state", "type": "uint8" },
        { "offset": 2, "name": "old_state", "type": "uint8" },
        { "offset": 3, "name": "source_id", "type": "uint8" },
        { "offset": 4, "name": "rule_id", "type": "uint8" },
        { "offset": 5, "name": "device_ms", "type": "uint32_le" },
        { "offset": 9, "name": "seq", "type": "uint16_le" }
      ],
      "source_map": { "0": "BOOT", "1": "RULE", "2": "MANUAL", "3": "DOWNLINK" }
    }}
  ],
  "visualizations": [
    { "name": "Tank Levels", "viz_type": "time_series", "config": { "fields": ["level_pct"], "y_label": "Level", "y_unit": "%" }, "sort_order": 0 },
    { "name": "Flow Totals", "viz_type": "time_series", "config": { "fields": ["flow_t1_total", "flow_t2_total"], "y_label": "Volume", "y_unit": "L" }, "sort_order": 1 },
    { "name": "Battery", "viz_type": "gauge", "config": { "field": "battery", "color_ranges": [{ "max": 20, "color": "error" }, { "max": 50, "color": "warning" }, { "max": 100, "color": "success" }] }, "sort_order": 2 }
  ],
  "airconfig": {
    "pin_map": [0,0,0,4,7,7,2,2,2,2,2,2,4,0,0,0,0,0,0,0],
    "sensors": [
      { "type": 8, "pin_index": 3, "field_index": 0, "flags": 1, "param1": 0, "param2": 1000 },
      { "type": 1, "pin_index": 4, "field_index": 1, "flags": 1, "param1": 450, "param2": 0 },
      { "type": 1, "pin_index": 5, "field_index": 3, "flags": 1, "param1": 450, "param2": 0 },
      { "type": 2, "pin_index": 14, "field_index": 5, "flags": 1, "param1": 0, "param2": 0 }
    ],
    "controls": [
      { "pin_index": 6, "state_count": 2, "flags": 1, "actuator_type": 0, "pin2_index": 255, "pulse_x100ms": 0 },
      { "pin_index": 7, "state_count": 2, "flags": 5, "actuator_type": 1, "pin2_index": 8, "pulse_x100ms": 50 },
      { "pin_index": 9, "state_count": 2, "flags": 5, "actuator_type": 1, "pin2_index": 10, "pulse_x100ms": 50 },
      { "pin_index": 11, "state_count": 2, "flags": 1, "actuator_type": 0, "pin2_index": 255, "pulse_x100ms": 0 },
      { "pin_index": 12, "state_count": 2, "flags": 1, "actuator_type": 0, "pin2_index": 255, "pulse_x100ms": 0 },
      { "pin_index": 13, "state_count": 2, "flags": 9, "actuator_type": 2, "pin2_index": 255, "pulse_x100ms": 20 }
    ],
    "lorawan": { "region": 0, "sub_band": 2, "data_rate": 3, "tx_power": 22, "adr": true, "confirmed": true },
    "transfer": { "enabled": 1, "pump_ctrl": 0, "valve_t1_ctrl": 1, "valve_t2_ctrl": 2, "sv_ctrl": 5, "level_t1_field": 0, "level_t2_field": 0, "start_delta_pct": 20, "stop_t1_min_pct": 15, "measure_pulse_sec": 2 }
  }
}
